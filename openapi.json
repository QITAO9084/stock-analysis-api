              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/crypto/analyze": {
      "get": {
        "summary": "Analyze Crypto",
        "description": "加密货币分析接口（扁平化，适配 Coze 插件）\n\n复用现有技术指标计算逻辑，支持比特币、以太坊等主流加密货币。\nyfinance 格式：BTC-USD, ETH-USD, BNB-USD 等。\n\n- **symbol**: 加密货币代码（如 BTC-USD, ETH-USD）",
        "operationId": "analyze_crypto_crypto_analyze_get",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
