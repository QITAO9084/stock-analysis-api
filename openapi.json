    "/stock/scan": {
      "get": {
        "summary": "Scan Stocks",
        "description": "批量扫描买卖点接口（V5新增，适配 Coze 插件，扁平化返回）\n\n扫描一篮子股票，识别当前有明确买卖点的标的，按信号强度排序。\n支持自定义股票列表或使用默认热门列表。\n\n- **symbols**: 股票代码，逗号分隔（留空使用默认列表）\n- **market**: 市场（us/hk/cn）\n- **min_score**: 最低信号分数（默认3.0，只返回评分≥此值的标的）",
        "operationId": "scan_stocks_stock_scan_get",
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "Symbols"
            }
          },
          {
            "name": "market",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "us",
              "title": "Market"
            }
          },
          {
            "name": "min_score",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 3.0,
              "title": "Min Score"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stock/tradepoint": {
      "get": {
        "summary": "Get Trade Point Flat",
        "description": "单股精准买卖点接口（V5新增，扁平化，适配 Coze 插件）\n\n专精识别当前是否处于最佳买入/卖出时点。\n组合MACD、RSI、KDJ、布林带、均线、成交量六大维度，\n输出明确的买卖点类型、触发原因和价格建议。\n\n- **symbol**: 股票代码（如 AAPL, 0700, 002410）\n- **market**: 市场（us/hk/cn）",
        "operationId": "get_trade_point_flat_stock_tradepoint_get",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "AAPL",
              "title": "Symbol"
