{
  "openapi": "3.0.3",
  "info": {
    "title": "Stock Analysis API",
    "description": "美股港股买卖点分析接口，供 Coze AI Agent 调用",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://stock-analysis-api-n741.onrender.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/stock/info": {
      "get": {
        "summary": "获取股票基本信息",
        "operationId": "getStockInfo",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "股票代码，如 AAPL / 0700.HK"
            },
            "description": "股票代码，如 AAPL / 0700.HK"
          },
          {
            "name": "market",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "市场：us / hk / auto",
              "default": "auto"
            },
            "description": "市场：us / hk / auto"
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回股票基本信息",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "symbol": {"type": "string"},
                    "name": {"type": "string"},
                    "current_price": {"type": "number"},
                    "change_percent": {"type": "number"},
                    "currency": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stock/kline": {
      "get": {
        "summary": "获取K线数据和技术指标",
        "operationId": "getKline",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "股票代码"
            },
            "description": "股票代码"
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "周期：1mo/3mo/6mo/1y/2y",
              "default": "6mo"
            },
            "description": "周期：1mo/3mo/6mo/1y/2y"
          },
          {
            "name": "interval",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "K线间隔：1d/1wk/1mo",
              "default": "1d"
            },
            "description": "K线间隔：1d/1wk/1mo"
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回K线数据",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"type": "object"}
                }
              }
            }
          }
        }
      }
    },
    "/stock/signal": {
      "get": {
        "summary": "综合买卖信号分析",
        "operationId": "getSignal",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "market",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "auto"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回买卖信号",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "signals": {"type": "object"},
                    "recommendation": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stock/analyze": {
      "get": {
        "summary": "完整分析报告（一键调用）",
        "description": "Coze Agent 主要调用这个接口，一次拿到所有分析数据",
        "operationId": "fullAnalysis",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "market",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "auto"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回完整分析报告",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stock": {"type": "object"},
                    "indicators": {"type": "object"},
                    "signals": {"type": "object"},
                    "kline_60d": {
                      "type": "array",
                      "items": {"type": "object"}
                    },
                    "disclaimer": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/forex/analyze": {
      "get": {
        "summary": "汇率技术分析（支持USDCNY、USDJPY等）",
        "description": "分析主流汇率对的技术指标（RSI/MACD/KDJ/布林带/均线），返回扁平化数据适配Coze插件",
        "operationId": "forexAnalyze",
        "parameters": [
          {
            "name": "pair",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "汇率对代码，如 USDCNY、USDJPY、USDEUR、USDGBP、USDKRW、USDHKD",
              "default": "USDCNY"
            },
            "description": "汇率对代码，如 USDCNY、USDJPY、USDEUR、USDGBP、USDKRW、USDHKD"
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回汇率分析报告",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pair": {"type": "string", "description": "汇率对代码"},
                    "name": {"type": "string", "description": "汇率对中文名"},
                    "current_price": {"type": "number", "description": "当前汇率"},
                    "change_percent": {"type": "number", "description": "涨跌幅%"},
                    "volatility_20d": {"type": "number", "description": "20日波动率%"},
                    "signal": {"type": "string", "description": "BUY/SELL/HOLD"},
                    "confidence": {"type": "string", "description": "HIGH/MEDIUM/LOW"},
                    "rsi": {"type": "number"},
                    "rsi_prev": {"type": "number"},
                    "macd_histogram": {"type": "number"},
                    "kdj_k": {"type": "number"},
                    "kdj_d": {"type": "number"},
                    "trend_direction": {"type": "string"},
                    "key_signals_text": {"type": "string"},
                    "kline_text": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
