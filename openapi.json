    "/stock/compare": {
      "get": {
        "summary": "Compare Stocks",
        "description": "多股对比分析接口（专为 Coze 插件优化，扁平化返回）\n\n传入多个股票代码（逗号分隔），返回每只股票的核心指标对比。\n最多支持5只股票同时对比。\n\n- **symbols**: 股票代码，逗号分隔（如 \"AAPL,MSFT,GOOG\"）\n- **market**: 市场（us/hk）",
        "operationId": "compare_stocks_stock_compare_get",
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "AAPL,MSFT,GOOG",
              "title": "Symbols"
            }
          },
          {
            "name": "market",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "us",
              "title": "Market"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
