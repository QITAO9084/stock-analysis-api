    "/ganzhi/map": {
      "get": {
        "tags": [
          "双色球玄学映射"
        ],
        "summary": "Ganzhi Map",
        "description": "双色球玄学号码映射接口 - 根据天干地支返回对应红球蓝球号码。\n参数从知识库查询结果中获取，传入本接口获取准确的号码映射。",
        "operationId": "ganzhi_map_ganzhi_map_get",
        "parameters": [
          {
            "name": "year_gan",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "甲",
              "title": "Year Gan"
            }
          },
          {
            "name": "year_zhi",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "子",
              "title": "Year Zhi"
            }
          },
          {
            "name": "month_gan",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "甲",
              "title": "Month Gan"
            }
          },
          {
            "name": "month_zhi",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "子",
              "title": "Month Zhi"
            }
          },
          {
            "name": "day_gan",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "甲",
              "title": "Day Gan"
            }
          },
          {
            "name": "day_zhi",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "子",
              "title": "Day Zhi"
            }
          },
          {
            "name": "lunar_day",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "title": "Lunar Day"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
